# Multi-material cube: each face pair has a different material
# Tests per-face color via usemtl

v 0 0 0
v 1 0 0
v 1 1 0
v 0 1 0
v 0 0 1
v 1 0 1
v 1 1 1
v 0 1 1

vn 0 0 -1
vn 0 0 1
vn 0 -1 0
vn 0 1 0
vn -1 0 0
vn 1 0 0

# Front face (z=0) - red
usemtl red
f 1//1 3//1 2//1
f 1//1 4//1 3//1

# Back face (z=1) - green
usemtl green
f 5//2 6//2 7//2
f 5//2 7//2 8//2

# Bottom face (y=0) - blue
usemtl blue
f 1//3 2//3 6//3
f 1//3 6//3 5//3

# Top face (y=1) - yellow
usemtl yellow
f 4//4 8//4 7//4
f 4//4 7//4 3//4

# Left face (x=0) - cyan
usemtl cyan
f 1//5 5//5 8//5
f 1//5 8//5 4//5

# Right face (x=1) - magenta
usemtl magenta
f 2//6 3//6 7//6
f 2//6 7//6 6//6
